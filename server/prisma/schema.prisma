generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Employee {
  id        String   @id @default(uuid())
  name      String
  rank      String
  jobDesc   String
  model     String   @default("opencode/big-pickle")
  port      Int      @unique
  status    String   @default("offline")
  positionX Float    @default(0)
  positionY Float    @default(0)
  supervisorId String?
  supervisor   Employee?  @relation("Supervisor", fields: [supervisorId], references: [id])
  subordinates Employee[] @relation("Supervisor")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chats       Chat[]
  jobs        Job[]
  files       File[]
  notes       Note[]
}

model Chat {
  id         String   @id @default(uuid())
  employeeId String
  role       String
  content    String
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Job {
  id          String    @id @default(uuid())
  employeeId  String
  name        String
  schedule    String
  prompt      String
  status      String    @default("active")
  lastRun     DateTime?
  lastResult  String?
  lastOutput  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model File {
  id         String   @id @default(uuid())
  employeeId String
  path       String
  content    String   @default("")
  size       Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  actor     String
  action    String
  target    String?
  detail    String?
  createdAt DateTime @default(now())
}

model Note {
  id         String   @id @default(uuid())
  title      String
  content    String
  employeeId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
}
